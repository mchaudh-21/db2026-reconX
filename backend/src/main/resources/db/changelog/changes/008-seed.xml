<?xml version="1.0" encoding="UTF-8"?>
<!--
============================================================================
TICKET-ADV017 — Deterministic development and test seed data

Loads:
- 10 counterparties
- 5 explicit instruments from CSV
- 45 generated instruments
- 4 BCrypt-hashed users
- 500 trades distributed evenly across April through July 2026

All seed changesets are restricted to dev and test contexts and guarded by
preconditions so restarting the application does not duplicate records.
============================================================================
-->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="008-seed-counterparties" author="philemon" context="dev,test">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <and>
                <tableExists tableName="counterparties"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM counterparties
                </sqlCheck>
            </and>
        </preConditions>

        <loadData
                file="data/counterparties.csv"
                tableName="counterparties"
                separator=","
                relativeToChangelogFile="true">
            <column name="id" type="NUMERIC"/>
            <column name="name" type="STRING"/>
            <column name="lei_code" type="STRING"/>
            <column name="region" type="STRING"/>
        </loadData>

        <rollback>
            <sql>DELETE FROM counterparties WHERE id BETWEEN 1 AND 10;</sql>
        </rollback>
    </changeSet>

    <changeSet id="008-seed-explicit-instruments"
               author="philemon"
               context="dev,test">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <and>
                <tableExists tableName="instruments"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM instruments
                </sqlCheck>
            </and>
        </preConditions>

        <loadData
                file="data/instruments.csv"
                tableName="instruments"
                separator=","
                relativeToChangelogFile="true">
            <column name="id" type="NUMERIC"/>
            <column name="symbol" type="STRING"/>
            <column name="name" type="STRING"/>
            <column name="asset_class" type="STRING"/>
            <column name="currency" type="STRING"/>
            <column name="isin" type="STRING"/>
        </loadData>

        <rollback>
            <sql>DELETE FROM instruments WHERE id BETWEEN 1 AND 5;</sql>
        </rollback>
    </changeSet>

    <changeSet id="008-seed-generated-instruments"
               author="philemon"
               context="dev,test">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <and>
                <dbms type="postgresql"/>
                <tableExists tableName="instruments"/>
                <sqlCheck expectedResult="5">
                    SELECT COUNT(*) FROM instruments
                </sqlCheck>
            </and>
        </preConditions>

        <sql splitStatements="true" stripComments="true"><![CDATA[
            INSERT INTO instruments (
                id,
                symbol,
                name,
                asset_class,
                currency,
                isin
            )
            SELECT
                n,
                'GEN' || LPAD(n::TEXT, 3, '0'),
                'Generated Instrument ' || n,
                CASE n % 4
                    WHEN 0 THEN 'EQUITY'
                    WHEN 1 THEN 'FIXED_INCOME'
                    WHEN 2 THEN 'FX'
                    ELSE 'DERIVATIVE'
                END,
                CASE n % 4
                    WHEN 0 THEN 'USD'
                    WHEN 1 THEN 'EUR'
                    WHEN 2 THEN 'GBP'
                    ELSE 'JPY'
                END,
                'XS' || LPAD(n::TEXT, 10, '0')
            FROM GENERATE_SERIES(6, 50) AS n;

            SELECT SETVAL(
                PG_GET_SERIAL_SEQUENCE('instruments', 'id'),
                (SELECT MAX(id) FROM instruments),
                true
            );
        ]]></sql>

        <rollback>
            <sql>DELETE FROM instruments WHERE id BETWEEN 6 AND 50;</sql>
        </rollback>
    </changeSet>

    <changeSet id="008-seed-users" author="philemon" context="dev,test">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <and>
                <tableExists tableName="users"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM users
                </sqlCheck>
            </and>
        </preConditions>

        <insert tableName="users">
            <column name="email" value="admin@db.com"/>
