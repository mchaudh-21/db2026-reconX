    <changeSet id="008-seed-trades" author="philemon" context="dev,test">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <and>
                <dbms type="postgresql"/>
                <tableExists tableName="trades"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM trades
                </sqlCheck>
                <sqlCheck expectedResult="10">
                    SELECT COUNT(*) FROM counterparties
                </sqlCheck>
                <sqlCheck expectedResult="50">
                    SELECT COUNT(*) FROM instruments
                </sqlCheck>
            </and>
        </preConditions>

        <sql splitStatements="true" stripComments="true"><![CDATA[
            INSERT INTO trades (
                trade_ref,
                instrument_id,
                counterparty_id,
                asset_class,
                side,
                quantity,
                price,
                trade_date,
                status
            )
            SELECT
                'RX-2026-' || LPAD(n::TEXT, 6, '0'),
                1 + ((n - 1) % 50),
                1 + ((n - 1) % 10),
                i.asset_class,
                CASE
                    WHEN n % 2 = 0 THEN 'BUY'
                    ELSE 'SELL'
                END,
                100 + (n % 1000),
                10.25 + (n % 200),
                MAKE_DATE(
                    2026,
                    4 + ((n - 1) % 4),
                    1 + (((n - 1) / 4) % 28)
                ),
                CASE n % 3
                    WHEN 0 THEN 'MATCHED'
                    WHEN 1 THEN 'PENDING'
                    ELSE 'BREAK'
                END
            FROM GENERATE_SERIES(1, 500) AS n
            JOIN instruments AS i
              ON i.id = 1 + ((n - 1) % 50);
        ]]></sql>

        <rollback>
            <sql>
                DELETE FROM trades
                WHERE trade_ref LIKE 'RX-2026-%';
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>