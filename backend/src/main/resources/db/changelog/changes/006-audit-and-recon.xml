<?xml version="1.0" encoding="UTF-8"?>
<!--
============================================================================
audit_log, recon_breaks, and recon_jobs

ADV007 compatibility:
On PostgreSQL, recon_breaks references the partitioned trades table through
the composite key (trade_id, trade_date). Other databases keep the original
single-column trade_id foreign key.
============================================================================
-->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="006-create-audit-log" author="trainer">
        <createTable tableName="audit_log">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="event_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="trade_ref" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="event_timestamp" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="actor" type="VARCHAR(100)"/>
            <column name="before_state" type="CLOB"/>
            <column name="after_state" type="CLOB"/>
        </createTable>

        <createIndex tableName="audit_log" indexName="idx_audit_log_trade_ref">
            <column name="trade_ref"/>
        </createIndex>

        <rollback>
            <dropTable tableName="audit_log"/>
        </rollback>
    </changeSet>

    <changeSet id="006-create-recon-breaks" author="trainer">
        <createTable tableName="recon_breaks">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="trade_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="trade_date" type="DATE"/>
            <column name="discrepancy_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="OPEN">
                <constraints nullable="false"/>
            </column>
            <column name="detected_at"
                    type="TIMESTAMP"
                    defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="resolved_at" type="TIMESTAMP"/>
            <column name="resolution_note" type="VARCHAR(500)"/>
        </createTable>

        <rollback>
            <dropTable tableName="recon_breaks"/>
        </rollback>
    </changeSet>

    <changeSet id="006-recon-breaks-trade-fk-postgresql" author="david">
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
        </preConditions>

        <addNotNullConstraint tableName="recon_breaks"
                              columnName="trade_date"
                              columnDataType="DATE"/>

        <addForeignKeyConstraint
                baseTableName="recon_breaks"
                baseColumnNames="trade_id,trade_date"
                constraintName="fk_recon_breaks_trade"
                referencedTableName="trades"
                referencedColumnNames="id,trade_date"/>

        <rollback>
            <dropForeignKeyConstraint
                    baseTableName="recon_breaks"
                    constraintName="fk_recon_breaks_trade"/>
            <dropNotNullConstraint tableName="recon_breaks"
                                   columnName="trade_date"
                                   columnDataType="DATE"/>
        </rollback>
    </changeSet>

    <changeSet id="006-recon-breaks-trade-fk-other-db" author="trainer">
        <preConditions onFail="MARK_RAN">
            <not>
                <dbms type="postgresql"/>
            </not>
        </preConditions>

        <addForeignKeyConstraint
                baseTableName="recon_breaks"
                baseColumnNames="trade_id"
                constraintName="fk_recon_breaks_trade"
                referencedTableName="trades"
                referencedColumnNames="id"/>

        <rollback>
            <dropForeignKeyConstraint
                    baseTableName="recon_breaks"
                    constraintName="fk_recon_breaks_trade"/>
        </rollback>
    </changeSet>

    <changeSet id="006-create-recon-jobs" author="trainer">
        <createTable tableName="recon_jobs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="job_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="from_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="to_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="QUEUED"/>
            <column name="started_at" type="TIMESTAMP"/>
            <column name="finished_at" type="TIMESTAMP"/>
            <column name="trades_processed" type="INT" defaultValueNumeric="0"/>
            <column name="breaks_detected" type="INT" defaultValueNumeric="0"/>
        </createTable>

        <rollback>
            <dropTable tableName="recon_jobs"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
